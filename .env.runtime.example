# Copy to .env.runtime and fill in real values.
# This file is pushed into the enclave via VSOCK:7000 at startup.
# It never appears in the EIF image or PCR measurements.

# ── Required ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://user:pass@db.supabase.co:5432/postgres
REDIS_URL=rediss://default:token@region.upstash.io:6379

# Sui operator keypair — held by the sidecar, signs + submits PTBs.
# Generate with: sui keytool generate ed25519
# Export with:  sui keytool export --key-identity <alias>
OPERATOR_PRIVATE_KEY=suiprivkey1...

# Published package address (from: sui client publish)
PINAIVU_PACKAGE_ID=0x...

# EnclaveConfig<ENCLAVE> shared object id (created at publish time)
PINAIVU_ENCLAVE_CONFIG_ID=0x...

# Cap<ENCLAVE> owned object id (held by operator address)
PINAIVU_CAP_ID=0x...

# Vault<SUI> shared object id (created by vault::new_vault)
PINAIVU_VAULT_ID=0x...

# ── Optional (defaults shown) ─────────────────────────────────────────────────
# SUI_RPC_URL=https://fullnode.mainnet.sui.io
# SUI_NETWORK=mainnet
# PINAIVU_BIND=127.0.0.1:4000
# PINAIVU_LIBP2P_LISTEN=/ip4/0.0.0.0/tcp/4001
