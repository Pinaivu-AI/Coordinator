# Local development env — loaded automatically by the coordinator on startup.
# Matches the docker-compose.yml services above.
# DO NOT commit secrets here. This file is gitignored.

DATABASE_URL=postgres://pinaivu:pinaivu@localhost:5432/pinaivu
REDIS_URL=redis://localhost:6379

# Coordinator HTTP bind (HTTPS with self-signed cert)
PINAIVU_BIND=127.0.0.1:4000

# libp2p mesh (ephemeral port, fine for local dev)
PINAIVU_LIBP2P_LISTEN=/ip4/127.0.0.1/tcp/0

# Admin secret used by the dashboard to create accounts and keys
SIDECAR_SECRET=local-dev-secret
