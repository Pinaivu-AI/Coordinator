# Copy to .env.local and fill in the values.

# Coordinator endpoint (default points to the live AWS instance)
COORDINATOR_URL=https://13.206.80.190:4000

# Admin secret — same as SIDECAR_SECRET in the coordinator's env
SIDECAR_SECRET=your-sidecar-secret-here

# The operator account UUID created via POST /v1/accounts
DASHBOARD_ACCOUNT_ID=

# An active API key belonging to that account (used for GET /v1/usage)
DASHBOARD_API_KEY=sk-pnv-
