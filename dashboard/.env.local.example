# Copy to .env.local and fill in the values.
# For LOCAL dev, point at the coordinator running on your machine.
# For LIVE testing, point at the AWS instance.

# ── Coordinator endpoint ──────────────────────────────────────────────────────
# Local:
COORDINATOR_URL=https://localhost:4000
# Live:
# COORDINATOR_URL=https://13.206.80.190:4000

# ── Admin secret ──────────────────────────────────────────────────────────────
# Must match SIDECAR_SECRET in the coordinator's .env.dev (local) or
# .env.runtime (live). Used server-side only — never sent to the browser.
# Local:
SIDECAR_SECRET=local-dev-secret
# Live:
# SIDECAR_SECRET=your-live-secret-here

# ── Account + key (fill after running the Setup page) ────────────────────────
# Go to http://localhost:3000/setup to create these automatically, or
# run api_test.py once and copy the values from its output.
DASHBOARD_ACCOUNT_ID=
DASHBOARD_API_KEY=sk-pnv-

# ── TLS ───────────────────────────────────────────────────────────────────────
# Set to "false" only when the coordinator has a real CA-signed cert.
# Leave unset (or any other value) to skip TLS verification for
# self-signed enclave certs.
# COORDINATOR_SKIP_TLS_VERIFY=false
